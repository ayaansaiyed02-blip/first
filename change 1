];

// ═══════════════════════════════════════════════════
// STATE
// ═══════════════════════════════════════════════════
const MEALS = ["Breakfast","Lunch","Dinner","Snacks"];
let currentFilter = 'all';
let selectedFood = null;
let selectedMeal = 'Breakfast';
let goals = JSON.parse(localStorage.getItem('goals')||'{}');
if(!goals.cal) goals = {cal:2000,p:150,c:250,f:65,fi:30};

function todayKey(){return new Date().toISOString().slice(0,10);}
function getLog(){return JSON.parse(localStorage.getItem('log_'+todayKey())||'[]');}
function saveLog(log){localStorage.setItem('log_'+todayKey(),JSON.stringify(log));}

// ═══════════════════════════════════════════════════
// NAVIGATION
// ═══════════════════════════════════════════════════
function showPage(id,btn){
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.nav-btn').forEach(b=>b.classList.remove('active'));
  document.getElementById('page-'+id).classList.add('active');
  if(btn) btn.classList.add('active');
  if(id==='home') renderHome();
  if(id==='goals') renderGoals();
  if(id==='history') renderHistory();
  if(id==='search') {doSearch(); document.getElementById('searchInput').focus();}
}

// ═══════════════════════════════════════════════════
// HOME
// ═══════════════════════════════════════════════════
function renderHome(){
  const log = getLog();
  let totalCal=0,totalP=0,totalC=0,totalF=0,totalFi=0;
  log.forEach(item=>{
    const ratio = item.qty/100;
    totalCal += item.food.cal * ratio;
    totalP += item.food.p * ratio;
    totalC += item.food.c * ratio;
    totalF += item.food.f * ratio;
    totalFi += item.food.fi * ratio;
  });
  totalCal=Math.round(totalCal); totalP=Math.round(totalP);
  totalC=Math.round(totalC); totalF=Math.round(totalF); totalFi=Math.round(totalFi);

  const pct = Math.min(totalCal/goals.cal,1);
  const circ = 465;
  document.getElementById('ringFill').style.strokeDashoffset = circ - circ*pct;
  document.getElementById('ringFill').style.stroke = pct>1 ? '#ff4444' : 'var(--accent)';
  document.getElementById('calConsumed').textContent = totalCal.toLocaleString();
  document.getElementById('calGoalDisp').textContent = goals.cal.toLocaleString();
  const rem = goals.cal - totalCal;
  const remEl = document.getElementById('calRemaining');
  remEl.textContent = rem>=0 ? rem+' left' : Math.abs(rem)+' over';
  remEl.style.color = rem>=0 ? 'var(--green)' : '#ff4444';

  document.getElementById('totalProtein').textContent = totalP+'g';
  document.getElementById('totalCarbs').textContent = totalC+'g';
  document.getElementById('totalFat').textContent = totalF+'g';
  const setBar=(id,val,goal)=>{
    const pct = Math.min(val/goal*100,100);
    document.getElementById(id).style.width = pct+'%';
    document.getElementById(id+'Val').textContent = val+'/'+goal+'g';
  };
  setBar('barProtein',totalP,goals.p);
  setBar('barCarbs',totalC,goals.c);
  setBar('barFat',totalF,goals.f);
  setBar('barFiber',totalFi,goals.fi);

  const container = document.getElementById('mealsContainer');
  container.innerHTML='';
  MEALS.forEach(meal=>{
    const items = log.filter(i=>i.meal===meal);
    const mealCal = Math.round(items.reduce((s,i)=>s+i.food.cal*(i.qty/100),0));
    const div = document.createElement('div');
    div.className='card meal-section';
    const icons = {Breakfast:'🌅',Lunch:'☀️',Dinner:'🌙',Snacks:'🍎'};
    div.innerHTML=`<div class="meal-header">
      <span class="meal-title">${icons[meal]} ${meal}</span>
      <span class="meal-kcal">${mealCal} kcal</span>
      <button class="add-btn" onclick="openSearchForMeal('${meal}')">+ Add</button>
    </div>
    ${items.length===0?`<div class="empty" style="padding:14px 0 4px;"><div class="empty-txt" style="font-size:12px;">No items yet</div></div>`:''}
    ${items.map(item=>`<div class="log-item">
      <div>
        <div class="log-name">${item.food.name}</div>
        <div class="log-brand">${item.food.brand} · ${item.portion||item.qty+'g'}</div>
      </div>
      <div class="log-right">
        <div class="log-cal">${Math.round(item.food.cal*item.qty/100)}</div>
        <button class="log-del" onclick="delLog('${item.id}')">✕</button>
      </div>
    </div>`).join('')}`;
    container.appendChild(div);
  });
}

function openSearchForMeal(meal){
  selectedMeal = meal;
  document.querySelectorAll('.meal-chip').forEach(c=>{
    c.classList.toggle('sel', c.dataset.meal===meal);
  });
  showPage('search', document.querySelector('.nav-btn:nth-child(2)'));
}

function delLog(id){
  let log = getLog();
  log = log.filter(i=>i.id!==id);
  saveLog(log);
  renderHome();
}

// ═══════════════════════════════════════════════════
// SEARCH
// ═══════════════════════════════════════════════════
function setFilter(f, el){
  currentFilter=f;
  document.querySelectorAll('.chip').forEach(c=>c.classList.remove('active'));
  el.classList.add('active');
  doSearch();
}

function doSearch(){
  const q = document.getElementById('searchInput').value.toLowerCase().trim();
  let results = FOODS;
  if(currentFilter==='indian') results = results.filter(f=>f.region==='indian'||f.region==='both');
  else if(currentFilter==='brand') results = results.filter(f=>f.brand!=='Homemade'&&f.brand!=='Generic'&&f.brand!=='Fresh');
  else if(currentFilter!=='all') results = results.filter(f=>f.cat===currentFilter);
  if(q) results = results.filter(f=>
    f.name.toLowerCase().includes(q)||
    f.brand.toLowerCase().includes(q)
  );
  results = results.slice(0,60);
  const container = document.getElementById('searchResults');
  if(results.length===0){
    container.innerHTML='<div class="empty"><div class="empty-icon">🔍</div><div class="empty-txt">No results found</div></div>';
    return;
  }
  container.innerHTML = results.map(f=>`
    <div class="food-result" onclick="openAddModal(${f.id})">
      <div class="food-info">
        <div class="food-rname">${f.name}</div>
        <div class="food-rbrand">${f.brand}</div>
        <div class="food-rmacros">P:${f.p}g · C:${f.c}g · F:${f.f}g · per 100g</div>
      </div>
      <div style="text-align:right;">
        <div class="food-rcal">${f.cal}</div>
        <div class="food-rcal-unit">kcal/100g</div>
      </div>
    </div>
  `).join('');
}

// ═══════════════════════════════════════════════════
// MODAL + PORTIONS
// ═══════════════════════════════════════════════════
function getPortions(food){
  return PORTION_PRESETS[food.cat] || PORTION_PRESETS.default;
}

function openAddModal(foodId){
  selectedFood = FOODS.find(f=>f.id===foodId);
  if(!selectedFood) return;
  document.getElementById('modalFoodName').textContent = selectedFood.name;
  document.getElementById('modalFoodBrand').textContent = selectedFood.brand + ' · per 100g';
  document.getElementById('modalQty').value = 100;

  // Build portion chips
  const portions = getPortions(selectedFood);
  const chipsEl = document.getElementById('portionChips');
  chipsEl.innerHTML = portions.map((p,i)=>
    `<span class="portion-chip" onclick="applyPortion(${p.g},'${p.label}',this)">${p.label} (${p.g}g)</span>`
  ).join('');

  updateModalCalc();
  document.querySelectorAll('.meal-chip').forEach(c=>{
    c.classList.toggle('sel', c.dataset.meal===selectedMeal);
    c.onclick = ()=>{
      document.querySelectorAll('.meal-chip').forEach(x=>x.classList.remove('sel'));
      c.classList.add('sel');
      selectedMeal = c.dataset.meal;
    };
  });
  document.getElementById('addModal').classList.add('open');
}

function applyPortion(grams, label, el){
  document.getElementById('modalQty').value = grams;
  document.querySelectorAll('.portion-chip').forEach(c=>c.classList.remove('sel-portion'));
  el.classList.add('sel-portion');
  // store label for display
  if(selectedFood) selectedFood._portionLabel = label + ' (' + grams + 'g)';
  updateModalCalc();
}

function clearPortionSel(){
  document.querySelectorAll('.portion-chip').forEach(c=>c.classList.remove('sel-portion'));
  if(selectedFood) selectedFood._portionLabel = null;
}

function updateModalCalc(){
  if(!selectedFood) return;
  const qty = parseFloat(document.getElementById('modalQty').value)||100;
  const ratio = qty/100;
  document.getElementById('modalCalcCal').textContent = Math.round(selectedFood.cal*ratio);
  document.getElementById('modalNutTable').innerHTML = `
    <tr><td>Energy</td><td>${Math.round(selectedFood.cal*ratio)} kcal</td></tr>
    <tr><td>Protein</td><td>${(selectedFood.p*ratio).toFixed(1)}g</td></tr>
    <tr><td>Carbohydrates</td><td>${(selectedFood.c*ratio).toFixed(1)}g</td></tr>
    <tr><td>Fat</td><td>${(selectedFood.f*ratio).toFixed(1)}g</td></tr>
    <tr><td>Fiber</td><td>${(selectedFood.fi*ratio).toFixed(1)}g</td></tr>
  `;
}

function closeModal(){
  document.getElementById('addModal').classList.remove('open');
  if(selectedFood) selectedFood._portionLabel = null;
}

function closeModalBg(e){
  if(e.target===document.getElementById('addModal')) closeModal();
}

function confirmAdd(){
  if(!selectedFood) return;
  const qty = parseFloat(document.getElementById('modalQty').value)||100;
  const portionLabel = selectedFood._portionLabel || (qty+'g');
  const log = getLog();
  log.push({
    id: Date.now().toString(),
    food: selectedFood,
    qty: qty,
    portion: portionLabel,
    meal: selectedMeal,
    time: new Date().toISOString()
  });
  saveLog(log);
  closeModal();
  showPage('home', document.querySelector('.nav-btn:nth-child(1)'));
}

// ═══════════════════════════════════════════════════
// GOALS
// ═══════════════════════════════════════════════════
function renderGoals(){
  document.getElementById('goalCal').value = goals.cal;
  document.getElementById('goalProtein').value = goals.p;
  document.getElementById('goalCarbs').value = goals.c;
  document.getElementById('goalFat').value = goals.f;
  document.getElementById('goalFiber').value = goals.fi;

  const log = getLog();
  let totalCal=0,totalP=0,totalC=0,totalF=0;
  log.forEach(item=>{
    const ratio=item.qty/100;
    totalCal+=item.food.cal*ratio;
    totalP+=item.food.p*ratio;
    totalC+=item.food.c*ratio;
    totalF+=item.food.f*ratio;
  });
  document.getElementById('statsGrid').innerHTML=`
    <div class="stat-card"><div class="stat-val" style="color:var(--accent)">${Math.round(totalCal)}</div><div class="stat-lbl">Calories Consumed</div></div>
    <div class="stat-card"><div class="stat-val" style="color:var(--green)">${Math.round(goals.cal-totalCal)}</div><div class="stat-lbl">Calories Remaining</div></div>
    <div class="stat-card"><div class="stat-val" style="color:#4cc9f0">${Math.round(totalP)}g</div><div class="stat-lbl">Protein Today</div></div>
    <div class="stat-card"><div class="stat-val" style="color:#ffd166">${Math.round(totalC)}g</div><div class="stat-lbl">Carbs Today</div></div>
  `;
}

function saveGoals(){
  goals = {
    cal: parseInt(document.getElementById('goalCal').value)||2000,
    p: parseInt(document.getElementById('goalProtein').value)||150,
    c: parseInt(document.getElementById('goalCarbs').value)||250,
    f: parseInt(document.getElementById('goalFat').value)||65,
    fi: parseInt(document.getElementById('goalFiber').value)||30,
  };
  localStorage.setItem('goals',JSON.stringify(goals));
  renderHome();
  const btn = document.querySelector('.save-goal-btn');
  btn.textContent = '✓ Saved!';
  setTimeout(()=>{btn.textContent='Save Goals';},2000);
}

function calcTDEE(){
  const w = parseFloat(document.getElementById('bodyWeight').value);
  const h = parseFloat(document.getElementById('bodyHeight').value);
  const a = parseFloat(document.getElementById('bodyAge').value);
  const act = parseFloat(document.getElementById('bodyActivity').value);
  const g = document.getElementById('bodyGender').value;
  if(!w||!h||!a){document.getElementById('tdeeResult').textContent='Please fill all fields.';return;}
  let bmr = g==='m' ? 10*w + 6.25*h - 5*a + 5 : 10*w + 6.25*h - 5*a - 161;
  const tdee = Math.round(bmr * act);
  document.getElementById('tdeeResult').innerHTML = `
    <div style="background:var(--bg3);border-radius:var(--radius-sm);padding:14px;text-align:left;">
      <div style="font-size:11px;color:var(--muted);margin-bottom:4px;">ESTIMATED DAILY CALORIE NEED</div>
      <div style="font-family:'Syne',sans-serif;font-size:32px;font-weight:800;color:var(--accent2);">${tdee} kcal</div>
      <div style="font-size:11px;color:var(--muted);margin-top:6px;">
        🎯 Weight Loss: ~${tdee-500} kcal<br>
        ⚖️ Maintenance: ~${tdee} kcal<br>
        💪 Weight Gain: ~${tdee+500} kcal
      </div>
      <button onclick="setTDEEGoal(${tdee})" style="margin-top:10px;background:rgba(255,107,53,0.2);border:1px solid var(--accent);color:var(--accent);border-radius:20px;padding:6px 14px;font-size:12px;font-weight:600;cursor:pointer;font-family:'DM Sans',sans-serif;">Apply as Goal</button>
    </div>`;
}

function setTDEEGoal(cal){
  document.getElementById('goalCal').value = cal;
  saveGoals();
}

// ═══════════════════════════════════════════════════
// HISTORY
// ═══════════════════════════════════════════════════
function renderHistory(){
  const days=[];
  for(let i=6;i>=0;i--){
    const d = new Date(); d.setDate(d.getDate()-i);
    const key = d.toISOString().slice(0,10);
    const log = JSON.parse(localStorage.getItem('log_'+key)||'[]');
    const total = Math.round(log.reduce((s,item)=>s+item.food.cal*(item.qty/100),0));
    days.push({date:key, total, label:i===0?'Today':i===1?'Yesterday':d.toLocaleDateString('en-IN',{weekday:'short',month:'short',day:'numeric'})});
  }
  const maxCal = Math.max(...days.map(d=>d.total),goals.cal);
  const container = document.getElementById('historyCard');
  if(days.every(d=>d.total===0)){
    container.innerHTML='<div class="empty"><div class="empty-icon">📅</div><div class="empty-txt">Log food to see history</div></div>';
    return;
  }
  container.innerHTML = days.map(d=>`
    <div class="hist-day">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:4px;">
        <div class="hist-day-title">${d.label}</div>
        <div class="hist-goal-line" style="font-size:10px;">${d.total} / ${goals.cal} kcal</div>
      </div>
      <div class="hist-bar-row">
        <div class="hist-bar-bg">
          <div class="hist-bar-fill" style="width:${maxCal>0?Math.min(d.total/maxCal*100,100):0}%;background:${d.total>goals.cal?'#ff4444':'linear-gradient(90deg,var(--accent),var(--accent2))'}"></div>
        </div>
      </div>
    </div>
  `).join('');
}

// ═══════════════════════════════════════════════════
// INIT
// ═══════════════════════════════════════════════════
document.getElementById('todayLabel').textContent = new Date().toLocaleDateString('en-IN',{weekday:'short',day:'numeric',month:'short'});
doSearch();
renderHome();

setTimeout(()=>{
  const b=document.getElementById('installBanner');
  if(b){ b.style.transition='opacity .5s'; b.style.opacity='0'; setTimeout(()=>b.remove(),500); }
},10000);
</script>
