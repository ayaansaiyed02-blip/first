<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="CalSnap">
<meta name="theme-color" content="#1a1a2e">
<title>CalSnap – Calorie Tracker</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #0f0f1a;
  --bg2: #16162a;
  --bg3: #1e1e35;
  --card: #1c1c30;
  --border: rgba(255,255,255,0.08);
  --accent: #ff6b35;
  --accent2: #ffd166;
  --green: #06d6a0;
  --blue: #4cc9f0;
  --purple: #9b5de5;
  --text: #f0f0ff;
  --muted: rgba(240,240,255,0.45);
  --radius: 18px;
  --radius-sm: 10px;
}
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent;}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;overflow-x:hidden;padding-bottom:80px;}
h1,h2,h3{font-family:'Syne',sans-serif;}

.topbar{position:sticky;top:0;z-index:100;background:linear-gradient(to bottom,var(--bg),transparent);padding:16px 20px 8px;display:flex;align-items:center;justify-content:space-between;}
.logo{font-family:'Syne',sans-serif;font-size:22px;font-weight:800;background:linear-gradient(135deg,var(--accent),var(--accent2));-webkit-background-clip:text;-webkit-text-fill-color:transparent;}
.date-chip{background:var(--bg3);border:1px solid var(--border);border-radius:20px;padding:5px 12px;font-size:12px;color:var(--muted);font-weight:500;}

.page{display:none;padding:0 16px;animation:fadeIn .25s ease;}
.page.active{display:block;}
@keyframes fadeIn{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}

.nav{position:fixed;bottom:0;left:0;right:0;background:rgba(22,22,42,0.95);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border-top:1px solid var(--border);display:flex;z-index:200;padding-bottom:env(safe-area-inset-bottom);}
.nav-btn{flex:1;padding:12px 4px 10px;display:flex;flex-direction:column;align-items:center;gap:4px;border:none;background:none;color:var(--muted);font-size:10px;font-family:'DM Sans',sans-serif;font-weight:500;cursor:pointer;transition:.2s;}
.nav-btn.active{color:var(--accent);}
.nav-icon{font-size:22px;line-height:1;}

.card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:18px;}
.card+.card{margin-top:12px;}

.ring-wrap{display:flex;flex-direction:column;align-items:center;padding:10px 0 4px;}
.ring-svg{transform:rotate(-90deg);}
.ring-inner{position:relative;display:inline-flex;align-items:center;justify-content:center;}
.ring-text{position:absolute;text-align:center;}
.ring-cal{font-family:'Syne',sans-serif;font-size:32px;font-weight:800;line-height:1;}
.ring-label{font-size:11px;color:var(--muted);margin-top:2px;}
.ring-sub{display:flex;gap:20px;margin-top:16px;width:100%;}
.ring-sub-item{flex:1;text-align:center;}
.ring-sub-val{font-family:'Syne',sans-serif;font-size:18px;font-weight:700;}
.ring-sub-lbl{font-size:10px;color:var(--muted);}

.macro-row{display:flex;flex-direction:column;gap:8px;margin-top:4px;}
.macro-item{display:flex;align-items:center;gap:10px;}
.macro-name{font-size:12px;font-weight:600;width:54px;color:var(--muted);}
.macro-bar-bg{flex:1;height:6px;background:rgba(255,255,255,0.07);border-radius:10px;overflow:hidden;}
.macro-bar-fill{height:100%;border-radius:10px;transition:width .6s cubic-bezier(.34,1.56,.64,1);}
.macro-val{font-size:12px;font-weight:600;min-width:40px;text-align:right;}

.meal-section{margin-top:12px;}
.meal-header{display:flex;align-items:center;justify-content:space-between;padding:10px 0 6px;}
.meal-title{font-family:'Syne',sans-serif;font-size:15px;font-weight:700;}
.meal-kcal{font-size:12px;color:var(--muted);}
.add-btn{background:rgba(255,107,53,0.15);border:1px solid rgba(255,107,53,0.3);color:var(--accent);border-radius:20px;padding:5px 12px;font-size:12px;font-weight:600;cursor:pointer;font-family:'DM Sans',sans-serif;}
.log-item{display:flex;align-items:center;justify-content:space-between;padding:10px 14px;background:var(--bg3);border-radius:var(--radius-sm);margin-bottom:6px;}
.log-name{font-size:13px;font-weight:500;max-width:180px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.log-brand{font-size:10px;color:var(--muted);}
.log-right{text-align:right;}
.log-cal{font-family:'Syne',sans-serif;font-size:14px;font-weight:700;color:var(--accent2);}
.log-del{background:none;border:none;color:var(--muted);font-size:18px;cursor:pointer;padding:0 0 0 10px;}

.search-bar{display:flex;align-items:center;gap:10px;background:var(--bg3);border:1px solid var(--border);border-radius:var(--radius);padding:12px 16px;margin-bottom:14px;}
.search-bar input{background:none;border:none;color:var(--text);font-size:15px;font-family:'DM Sans',sans-serif;flex:1;outline:none;}
.search-bar input::placeholder{color:var(--muted);}
.search-icon{font-size:18px;color:var(--muted);}
.filter-chips{display:flex;gap:8px;overflow-x:auto;padding-bottom:4px;scrollbar-width:none;margin-bottom:14px;}
.filter-chips::-webkit-scrollbar{display:none;}
.chip{padding:6px 14px;border-radius:20px;font-size:12px;font-weight:600;cursor:pointer;white-space:nowrap;border:1px solid var(--border);background:var(--bg3);color:var(--muted);transition:.2s;}
.chip.active{background:var(--accent);color:#fff;border-color:var(--accent);}
.food-result{display:flex;align-items:center;justify-content:space-between;padding:12px 16px;background:var(--card);border:1px solid var(--border);border-radius:var(--radius-sm);margin-bottom:8px;cursor:pointer;transition:.15s;}
.food-result:active{transform:scale(.98);}
.food-rname{font-size:14px;font-weight:600;}
.food-rbrand{font-size:11px;color:var(--muted);}
.food-rmacros{font-size:10px;color:var(--muted);margin-top:2px;}
.food-rcal{font-family:'Syne',sans-serif;font-size:18px;font-weight:800;color:var(--accent);}
.food-rcal-unit{font-size:10px;color:var(--muted);}

/* PORTION PRESETS */
.portion-section{margin-bottom:16px;}
.portion-label{font-size:12px;font-weight:600;color:var(--muted);margin-bottom:8px;}
.portion-chips{display:flex;gap:6px;flex-wrap:wrap;}
.portion-chip{padding:6px 11px;border-radius:20px;font-size:11px;font-weight:600;cursor:pointer;border:1px solid var(--border);background:var(--bg3);color:var(--muted);transition:.2s;white-space:nowrap;}
.portion-chip:hover,.portion-chip.sel-portion{background:rgba(255,209,102,0.2);border-color:var(--accent2);color:var(--accent2);}

.modal-bg{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.7);z-index:500;align-items:flex-end;}
.modal-bg.open{display:flex;}
.modal{background:var(--bg2);border-radius:var(--radius) var(--radius) 0 0;padding:24px 20px 40px;width:100%;max-height:82vh;overflow-y:auto;animation:slideUp .3s ease;}
@keyframes slideUp{from{transform:translateY(100%)}to{transform:translateY(0)}}
.modal-handle{width:40px;height:4px;background:var(--border);border-radius:2px;margin:0 auto 20px;}
.modal-title{font-family:'Syne',sans-serif;font-size:20px;font-weight:800;margin-bottom:4px;}
.modal-subtitle{font-size:13px;color:var(--muted);margin-bottom:20px;}
.modal-row{display:flex;gap:12px;align-items:center;margin-bottom:16px;}
.modal-label{font-size:13px;font-weight:600;color:var(--muted);min-width:70px;}
.modal-val{font-family:'Syne',sans-serif;font-size:15px;font-weight:700;}
.qty-input{background:var(--bg3);border:1px solid var(--border);border-radius:var(--radius-sm);color:var(--text);font-size:18px;font-family:'Syne',sans-serif;font-weight:700;padding:10px 14px;width:100px;outline:none;text-align:center;}
.unit-sel{background:var(--bg3);border:1px solid var(--border);border-radius:var(--radius-sm);color:var(--text);font-size:14px;padding:10px 10px;outline:none;font-family:'DM Sans',sans-serif;}
.meal-sel-row{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:20px;}
.meal-chip{padding:8px 16px;border-radius:20px;border:1px solid var(--border);background:var(--bg3);color:var(--muted);font-size:13px;font-weight:600;cursor:pointer;transition:.2s;font-family:'DM Sans',sans-serif;}
.meal-chip.sel{background:var(--accent);color:#fff;border-color:var(--accent);}
.add-log-btn{width:100%;background:linear-gradient(135deg,var(--accent),#ff8c5a);border:none;color:#fff;font-size:16px;font-weight:700;font-family:'Syne',sans-serif;padding:16px;border-radius:var(--radius);cursor:pointer;margin-top:8px;}
.modal-close{position:absolute;top:20px;right:20px;background:var(--bg3);border:none;color:var(--text);width:32px;height:32px;border-radius:50%;font-size:18px;cursor:pointer;display:flex;align-items:center;justify-content:center;}

.goal-input-row{display:flex;flex-direction:column;gap:6px;margin-bottom:16px;}
.goal-input-label{font-size:13px;font-weight:600;color:var(--muted);}
.goal-input{background:var(--bg3);border:1px solid var(--border);border-radius:var(--radius-sm);color:var(--text);font-size:18px;font-family:'Syne',sans-serif;font-weight:700;padding:12px 16px;outline:none;width:100%;}
.goal-input:focus{border-color:var(--accent);}
.save-goal-btn{width:100%;background:linear-gradient(135deg,var(--green),#04a87a);border:none;color:#fff;font-size:16px;font-weight:700;font-family:'Syne',sans-serif;padding:16px;border-radius:var(--radius);cursor:pointer;margin-top:8px;}
.stats-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-top:12px;}
.stat-card{background:var(--bg3);border:1px solid var(--border);border-radius:var(--radius-sm);padding:14px;}
.stat-val{font-family:'Syne',sans-serif;font-size:22px;font-weight:800;}
.stat-lbl{font-size:11px;color:var(--muted);margin-top:2px;}

.hist-day{margin-bottom:16px;}
.hist-day-title{font-family:'Syne',sans-serif;font-size:14px;font-weight:700;color:var(--muted);margin-bottom:8px;text-transform:uppercase;letter-spacing:.06em;}
.hist-bar-bg{flex:1;height:8px;background:rgba(255,255,255,0.07);border-radius:10px;overflow:hidden;}
.hist-bar-fill{height:100%;border-radius:10px;background:linear-gradient(90deg,var(--accent),var(--accent2));}
.hist-val{font-size:12px;font-weight:700;min-width:50px;text-align:right;}
.hist-goal-line{font-size:11px;color:var(--muted);}

.nut-table{width:100%;border-collapse:collapse;margin-top:8px;}
.nut-table td{padding:7px 0;font-size:13px;border-bottom:1px solid var(--border);}
.nut-table td:last-child{text-align:right;font-weight:600;}
.nut-table tr:last-child td{border-bottom:none;}
.section-title{font-family:'Syne',sans-serif;font-size:17px;font-weight:800;margin:20px 0 10px;}

.ring-bg{stroke:rgba(255,255,255,0.07);}
.ring-fill{stroke:var(--accent);stroke-linecap:round;transition:stroke-dashoffset .8s cubic-bezier(.34,1.56,.64,1);}

.empty{text-align:center;padding:30px 20px;color:var(--muted);}
.empty-icon{font-size:40px;margin-bottom:8px;}
.empty-txt{font-size:14px;}

.install-banner{background:linear-gradient(135deg,rgba(255,107,53,0.2),rgba(155,93,229,0.2));border:1px solid rgba(255,107,53,0.3);border-radius:var(--radius);padding:14px 16px;margin-bottom:14px;display:flex;align-items:center;gap:12px;}
.install-banner .ib-icon{font-size:28px;}
.install-banner .ib-text{font-size:12px;line-height:1.5;color:var(--text);}
.install-banner strong{font-size:13px;font-weight:700;}

.hist-bar-row{display:flex;align-items:center;gap:10px;margin-bottom:6px;}
</style>
</head>
<body>

<!-- TOP BAR -->
<div class="topbar">
  <div class="logo">🔥 CalSnap</div>
  <div class="date-chip" id="todayLabel"></div>
</div>

<!-- PAGE: HOME -->
<div class="page active" id="page-home">
  <div class="install-banner" id="installBanner">
    <div class="ib-icon">📲</div>
    <div class="ib-text"><strong>Install as App</strong><br>Safari → Share → Add to Home Screen</div>
  </div>
  <div class="card" style="padding:20px 18px 18px;">
    <div class="ring-wrap">
      <div class="ring-inner">
        <svg class="ring-svg" width="170" height="170" viewBox="0 0 170 170">
          <circle class="ring-bg" cx="85" cy="85" r="74" stroke-width="12" fill="none"/>
          <circle class="ring-fill" id="ringFill" cx="85" cy="85" r="74" stroke-width="12" fill="none"
            stroke-dasharray="465" stroke-dashoffset="465"/>
        </svg>
        <div class="ring-text">
          <div class="ring-cal" id="calConsumed">0</div>
          <div class="ring-label">of <span id="calGoalDisp">2000</span> kcal</div>
          <div style="font-size:11px;color:var(--green);font-weight:600;margin-top:4px;" id="calRemaining">2000 left</div>
        </div>
      </div>
      <div class="ring-sub" style="justify-content:center;">
        <div class="ring-sub-item">
          <div class="ring-sub-val" style="color:#4cc9f0;" id="totalProtein">0g</div>
          <div class="ring-sub-lbl">Protein</div>
        </div>
        <div class="ring-sub-item">
          <div class="ring-sub-val" style="color:#ffd166;" id="totalCarbs">0g</div>
          <div class="ring-sub-lbl">Carbs</div>
        </div>
        <div class="ring-sub-item">
          <div class="ring-sub-val" style="color:#ff6b9d;" id="totalFat">0g</div>
          <div class="ring-sub-lbl">Fat</div>
        </div>
      </div>
    </div>
    <div class="macro-row" style="margin-top:18px;">
      <div class="macro-item">
        <span class="macro-name" style="color:#4cc9f0;">Protein</span>
        <div class="macro-bar-bg"><div class="macro-bar-fill" style="background:#4cc9f0;" id="barProtein"></div></div>
        <span class="macro-val" style="color:#4cc9f0;" id="barProteinVal">0/150g</span>
      </div>
      <div class="macro-item">
        <span class="macro-name" style="color:#ffd166;">Carbs</span>
        <div class="macro-bar-bg"><div class="macro-bar-fill" style="background:#ffd166;" id="barCarbs"></div></div>
        <span class="macro-val" style="color:#ffd166;" id="barCarbsVal">0/250g</span>
      </div>
      <div class="macro-item">
        <span class="macro-name" style="color:#ff6b9d;">Fat</span>
        <div class="macro-bar-bg"><div class="macro-bar-fill" style="background:#ff6b9d;" id="barFat"></div></div>
        <span class="macro-val" style="color:#ff6b9d;" id="barFatVal">0/65g</span>
      </div>
      <div class="macro-item">
        <span class="macro-name" style="color:#06d6a0;">Fiber</span>
        <div class="macro-bar-bg"><div class="macro-bar-fill" style="background:#06d6a0;" id="barFiber"></div></div>
        <span class="macro-val" style="color:#06d6a0;" id="barFiberVal">0/30g</span>
      </div>
    </div>
  </div>
  <div id="mealsContainer"></div>
  <div style="height:10px;"></div>
</div>

<!-- PAGE: SEARCH -->
<div class="page" id="page-search">
  <div style="padding-top:4px;">
    <div class="search-bar">
      <span class="search-icon">🔍</span>
      <input type="text" id="searchInput" placeholder="Search 1000+ foods, brands…" oninput="doSearch()">
    </div>
    <div class="filter-chips" id="filterChips">
      <div class="chip active" onclick="setFilter('all',this)">All</div>
      <div class="chip" onclick="setFilter('indian',this)">🇮🇳 Indian</div>
      <div class="chip" onclick="setFilter('brand',this)">🏷️ Branded</div>
      <div class="chip" onclick="setFilter('protein',this)">💪 Protein</div>
      <div class="chip" onclick="setFilter('snack',this)">🍿 Snacks</div>
      <div class="chip" onclick="setFilter('grain',this)">🌾 Grains</div>
      <div class="chip" onclick="setFilter('dairy',this)">🥛 Dairy</div>
      <div class="chip" onclick="setFilter('fruit',this)">🍎 Fruits</div>
      <div class="chip" onclick="setFilter('veg',this)">🥦 Vegetables</div>
      <div class="chip" onclick="setFilter('fastfood',this)">🍔 Fast Food</div>
    </div>
    <div id="searchResults"></div>
  </div>
</div>

<!-- PAGE: GOALS -->
<div class="page" id="page-goals">
  <div class="section-title" style="margin-top:8px;">Daily Goals</div>
  <div class="card">
    <div class="goal-input-row">
      <div class="goal-input-label">🔥 Calorie Goal (kcal)</div>
      <input class="goal-input" type="number" id="goalCal" placeholder="2000">
    </div>
    <div class="goal-input-row">
      <div class="goal-input-label">💪 Protein Goal (g)</div>
      <input class="goal-input" type="number" id="goalProtein" placeholder="150">
    </div>
    <div class="goal-input-row">
      <div class="goal-input-label">🌾 Carbs Goal (g)</div>
      <input class="goal-input" type="number" id="goalCarbs" placeholder="250">
    </div>
    <div class="goal-input-row">
      <div class="goal-input-label">🥑 Fat Goal (g)</div>
      <input class="goal-input" type="number" id="goalFat" placeholder="65">
    </div>
    <div class="goal-input-row">
      <div class="goal-input-label">🌿 Fiber Goal (g)</div>
      <input class="goal-input" type="number" id="goalFiber" placeholder="30">
    </div>
    <button class="save-goal-btn" onclick="saveGoals()">Save Goals</button>
  </div>

  <div class="section-title">Body Info</div>
  <div class="card">
    <div class="goal-input-row">
      <div class="goal-input-label">⚖️ Weight (kg)</div>
      <input class="goal-input" type="number" id="bodyWeight" placeholder="70">
    </div>
    <div class="goal-input-row">
      <div class="goal-input-label">📏 Height (cm)</div>
      <input class="goal-input" type="number" id="bodyHeight" placeholder="170">
    </div>
    <div class="goal-input-row">
      <div class="goal-input-label">🎂 Age</div>
      <input class="goal-input" type="number" id="bodyAge" placeholder="25">
    </div>
    <div class="goal-input-row">
      <div class="goal-input-label">🏃 Activity</div>
      <select class="goal-input" id="bodyActivity" style="font-family:'DM Sans',sans-serif;">
        <option value="1.2">Sedentary (desk job)</option>
        <option value="1.375">Light (1-3 days/wk)</option>
        <option value="1.55" selected>Moderate (3-5 days/wk)</option>
        <option value="1.725">Active (6-7 days/wk)</option>
        <option value="1.9">Very Active (athlete)</option>
      </select>
    </div>
    <div class="goal-input-row">
      <div class="goal-input-label">⚤ Gender</div>
      <select class="goal-input" id="bodyGender" style="font-family:'DM Sans',sans-serif;">
        <option value="m">Male</option>
        <option value="f">Female</option>
      </select>
    </div>
    <button class="save-goal-btn" onclick="calcTDEE()" style="background:linear-gradient(135deg,var(--purple),#7b4dba);">Calculate TDEE</button>
    <div id="tdeeResult" style="margin-top:14px;text-align:center;font-size:13px;color:var(--muted);"></div>
  </div>

  <div class="section-title">Today's Stats</div>
  <div class="stats-grid" id="statsGrid"></div>
  <div style="height:10px;"></div>
</div>

<!-- PAGE: HISTORY -->
<div class="page" id="page-history">
  <div class="section-title" style="margin-top:8px;">Weekly Summary</div>
  <div class="card" id="historyCard">
    <div class="empty"><div class="empty-icon">📅</div><div class="empty-txt">Log food to see history</div></div>
  </div>
  <div style="height:10px;"></div>
</div>

<!-- BOTTOM NAV -->
<nav class="nav">
  <button class="nav-btn active" onclick="showPage('home',this)"><span class="nav-icon">🏠</span>Home</button>
  <button class="nav-btn" onclick="showPage('search',this)"><span class="nav-icon">🔍</span>Search</button>
  <button class="nav-btn" onclick="showPage('goals',this)"><span class="nav-icon">🎯</span>Goals</button>
  <button class="nav-btn" onclick="showPage('history',this)"><span class="nav-icon">📊</span>History</button>
</nav>

<!-- ADD FOOD MODAL -->
<div class="modal-bg" id="addModal" onclick="closeModalBg(event)">
  <div class="modal" style="position:relative;">
    <button class="modal-close" onclick="closeModal()">✕</button>
    <div class="modal-handle"></div>
    <div class="modal-title" id="modalFoodName">Food Name</div>
    <div class="modal-subtitle" id="modalFoodBrand">Brand · per 100g</div>

    <!-- Portion Presets -->
    <div class="portion-section">
      <div class="portion-label">⚡ Quick Portions</div>
      <div class="portion-chips" id="portionChips"></div>
    </div>

    <div style="display:flex;gap:12px;align-items:flex-end;margin-bottom:16px;">
      <div>
        <div class="modal-label" style="margin-bottom:6px;">Quantity (g)</div>
        <input class="qty-input" type="number" id="modalQty" value="100" oninput="updateModalCalc();clearPortionSel()">
      </div>
      <div style="flex:1;text-align:right;">
        <div style="font-size:11px;color:var(--muted);">Calories</div>
        <div style="font-family:'Syne',sans-serif;font-size:28px;font-weight:800;color:var(--accent);" id="modalCalcCal">100</div>
        <div style="font-size:10px;color:var(--muted);">kcal</div>
